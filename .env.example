# Django Settings
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1
ENVIRONMENT=production

# Database
# Development: Leave empty (will use SQLite)
# Production/Render: Set to your PostgreSQL database URL
DATABASE_URL=

# Security
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_BROWSER_XSS_FILTER=True
SECURE_CONTENT_SECURITY_POLICY=True
X_FRAME_OPTIONS=DENY

# Email (optional)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@example.com
EMAIL_HOST_PASSWORD=your-email-password

# Logging
LOG_LEVEL=INFO

# Render Deployment Notes:
# - Set DEBUG=False for production
# - Generate a new SECRET_KEY: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
# - Set ALLOWED_HOSTS to your Render URL (e.g., pizzacone.onrender.com)
# - Set DATABASE_URL to your Render PostgreSQL connection string
# - Enable all SECURE_* settings for production
